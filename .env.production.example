# Production Environment Configuration
# Copy this to .env.production and fill in secure values

# Authentication for API endpoints
AUTH_USERNAME=admin
AUTH_PASSWORD=YOUR_SECURE_API_PASSWORD_HERE

# Database - used by docker-compose
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD_HERE
DATABASE_URL=postgresql://scraper:YOUR_SECURE_DB_PASSWORD_HERE@postgres:5432/materials

# Server
PORT=3000
NODE_ENV=production

# Cache TTL in seconds
CACHE_TTL=3600
