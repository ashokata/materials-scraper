# Authentication
AUTH_USERNAME=admin
AUTH_PASSWORD=your_secure_password

# Cache TTL in seconds (1 hour default)
CACHE_TTL=3600

# Server
PORT=3000

# Scraper settings
SCRAPER_TIMEOUT=30000
SCRAPER_HEADLESS=true

# Database
DATABASE_URL="postgresql://scraper:your_password@localhost:5433/materials?schema=public"
